generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String             @id @default(cuid())
  email                   String             @unique
  name                    String
  passwordHash            String
  role                    Role               @default(TRAVELLER)
  avatar                  String?
  phone                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  idImage                 String?
  idNumber                String?
  idType                  String?
  isEmailVerified         Boolean            @default(false)
  mfaSecret               String?
  isMfaEnabled            Boolean            @default(false)
  theme                   String             @default("light")
  language                String             @default("en-US")
  isMobileVerified        Boolean            @default(false)
  verifiedEmail           Boolean            @default(false)
  verifiedPhone           Boolean            @default(false)
  verificationCompletedAt DateTime?
  kycStatus               String?            @default("NOT_SUBMITTED")
  kycRejectionReason      String?
  deletedAt               DateTime?
  fraudScore              Int                @default(0)
  fraudFlags              String[]           @default([])
  location                String?
  bookings                Booking[]
  guideBookings           GuideBooking[]
  guideProfile            GuideProfile?
  messages                Message[]
  notifications           Notification[]
  otpVerifications        OtpVerification[]
  ownerProfile            ResortOwner?
  reviews                 Review[]
  staffProfile            StaffMember?
  wishlist                Wishlist[]
  couponRedemptions       CouponRedemption[]
  referralsSent           Referral[]         @relation("Referrer")
  referralsReceived       Referral[]         @relation("ReferredUser")
  rewardCredits           RewardCredit[]
  blogPosts               BlogPost[]         @relation("BlogAuthor")
  adminSessions           AdminSession[]
  auditLogs               AuditLog[]
  travellerKycDocuments   TravellerKYC[]

  @@map("users")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  otpHash   String
  otpType   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model Resort {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  tagline          String
  description      String
  type             String
  locationArea     String
  locationLat      Float
  locationLng      Float
  images           String[]
  coverImage       String?
  amenities        String[]
  rating           Float           @default(0)
  reviewCount      Int             @default(0)
  pricePerNight    Float
  isFeatured       Boolean         @default(false)
  isVerified       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ownerId          String
  categories       String[]        @default([])
  houseRules       String[]
  mealPackages     Json?
  verificationDocs Json?
  status           ResortStatus    @default(PENDING)
  deletedAt        DateTime?
  commissionRate   Float           @default(7.0)
  boostScore       Int             @default(0)
  bookings         Booking[]
  discountCodes    DiscountCode[]
  invitations      Invitation[]
  owner            ResortOwner     @relation(fields: [ownerId], references: [id])
  reviews          Review[]
  roomTypes        Room[]
  staff            StaffMember[]
  wishlist         Wishlist[]
  resortAmenities  ResortAmenity[]
  coupons          Coupon[]        @relation("ResortCoupons")

  @@index([status])
  @@index([pricePerNight])
  @@index([rating])
  @@index([type])
  @@index([isFeatured])
  @@index([ownerId])
  @@map("resorts")
}

model Room {
  id             String              @id @default(cuid())
  name           String
  description    String
  pricePerNight  Float
  capacity       Int
  amenities      String[]
  images         String[]
  coverImage     String?
  availableCount Int
  resortId       String
  maxNights      Int                 @default(30)
  minNights      Int                 @default(1)
  externalIcalUrls String[]          @default([])
  bookings       Booking[]
  blockings      RoomBlocking[]
  priceOverrides RoomPriceOverride[]
  resort         Resort              @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("rooms")
}

model RoomPriceOverride {
  id        String   @id @default(cuid())
  date      DateTime
  price     Float
  minNights Int?
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_price_overrides")
}

model SystemSettings {
  id                      String   @id @default(cuid())
  guideServiceEnabled     Boolean  @default(true)
  defaultCommissionRate   Float    @default(7.0)
  requireOtpForSignup     Boolean  @default(true)
  maintenanceMode         Boolean  @default(false)
  detailedAuditLogging    Boolean  @default(true)
  notifyNewUsers          Boolean  @default(true)
  notifyHighValueBookings Boolean  @default(true)
  notifySystemAlerts      Boolean  @default(true)
  updatedBy               String?
  updatedAt               DateTime @updatedAt
}

model GuidePromotionSettings {
  id                      String   @id @default(cuid())
  enableRecommendations   Boolean  @default(true)
  enableSuccessUpsell     Boolean  @default(true)
  enableDashboardBanner   Boolean  @default(true)
  enableBundleOffers      Boolean  @default(true)
  bundleDiscountAmount    Float    @default(200.0)
  bannerText              String   @default("🏛️ Explore Hampi With a Local Expert")
  ctaText                 String   @default("Explore Guides")
  updatedBy               String?
  updatedAt               DateTime @updatedAt

  @@map("guide_promotion_settings")
}

model GuidePromotionAnalytics {
  id                    String   @id @default(cuid())
  impressions           Int      @default(0)
  clicks                Int      @default(0)
  profileViews          Int      @default(0)
  guideBookings         Int      @default(0)
  bundleConversions     Int      @default(0)
  revenueGenerated      Float    @default(0.0)
  date                  DateTime @default(now())

  @@map("guide_promotion_analytics")
}

model VerificationSettings {
  id                      String   @id @default(cuid())
  travellerRequirements   String[] @default(["MOBILE_OTP", "EMAIL_VERIFICATION"])
  resortOwnerRequirements String[] @default(["AADHAAR", "PAN"])
  guideRequirements       String[] @default(["AADHAAR"])
  updatedBy               String?
  updatedAt               DateTime @updatedAt

  @@map("verification_settings")
}


model RoomBlocking {
  id     String   @id @default(cuid())
  date   DateTime
  reason String?
  roomId String
  room   Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_blockings")
}

model DiscountCode {
  id               String   @id @default(cuid())
  code             String   @unique
  percentage       Float?
  flatAmount       Float?
  minBookingAmt    Float?
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  usedCount        Int      @default(0)
  isEarlyBird      Boolean  @default(false)
  minDaysInAdvance Int?
  isLastMinute     Boolean  @default(false)
  maxDaysInAdvance Int?
  resortId         String
  resort           Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("discount_codes")
}

model Booking {
  id               String            @id @default(cuid())
  checkIn          DateTime
  checkOut         DateTime
  guests           Int
  totalPrice       Float
  status           BookingStatus     @default(PENDING)
  specialRequests  String?
  referenceNumber  String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String
  resortId         String
  roomId           String?
  commissionRate   Float             @default(7.0)
  paymentStatus    String            @default("PENDING")
  payoutStatus     String            @default("PENDING")

  promotionId      String?
  promotionName    String?
  discountAmount   Float?
  promotion        Promotion?        @relation(fields: [promotionId], references: [id])

  resort           Resort            @relation(fields: [resortId], references: [id])
  room             Room?             @relation(fields: [roomId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  messages         Message[]
  couponRedemption CouponRedemption?

  @@index([resortId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([checkIn])
  @@index([checkOut])
  @@index([resortId, status])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Wishlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resortId])
  @@map("wishlist")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  comment   String?
  images    String[]
  createdAt DateTime @default(now())
  userId    String
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@index([userId])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  content         String    @db.Text
  excerpt         String?
  featuredImage   String?
  authorId        String
  categoryId      String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  metaTitle       String?
  metaDescription String?
  isFeatured      Boolean   @default(false)
  tags            String[]  @default([])

  author User @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([publishedAt])
  @@map("blog_posts")
}

model ResortOwner {
  id           String   @id @default(cuid())
  businessName String?
  gstNumber    String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resorts      Resort[]
  kycDocuments KycDocument[]
  bankAccount  BankAccount?

  @@map("resort_owners")
}

model KycDocument {
  id           String      @id @default(cuid())
  ownerId      String
  type         String      // AADHAAR, PAN
  documentUrl  String
  status       String      @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText String?
  rejectedReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  owner        ResortOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model BankAccount {
  id            String      @id @default(cuid())
  ownerId       String      @unique
  accountHolder String
  bankName      String
  accountNumber String
  ifsc          String
  status        String      @default("PENDING") // PENDING, VERIFIED, REJECTED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  owner         ResortOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model TravellerKYC {
  id             String    @id @default(cuid())
  userId         String
  type           String    // GOVERNMENT_ID, AADHAAR, PASSPORT
  documentUrl    String
  status         String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText  String?
  rejectedReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("traveller_kyc_documents")
}

model GuideProfile {
  id              String         @id @default(cuid())
  bio             String
  specialties     String[]
  languages       String[]
  pricePerDay     Float
  pricePerHour    Float
  yearsExperience Int
  contactNumber   String?
  emergencyContact String?
  city            String?
  state           String?
  profileCompletion Int          @default(0)
  isVerified      Boolean        @default(false)
  rating          Float          @default(0)
  reviewCount     Int            @default(0)
  images          String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String         @unique
  idImage         String?
  idNumber        String?
  idType          String?
  status          ResortStatus   @default(PENDING)
  rejectionReason String?
  isActive        Boolean        @default(true)
  deletedAt       DateTime?
  fraudScore      Int            @default(0)
  fraudFlags      String[]       @default([])
  experiences     Experience[]
  bookings        GuideBooking[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycDocuments    GuideKYC[]
  payouts         GuidePayout[]
  blockedDates    DateTime[]     @default([])

  @@map("guide_profiles")
}

model GuideBooking {
  id              String        @id @default(cuid())
  date            DateTime
  durationHours   Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  meetingPoint    String
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  guideId         String
  guide           GuideProfile  @relation(fields: [guideId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([guideId])
  @@index([userId])
  @@index([date])
  @@map("guide_bookings")
}

model Experience {
  id            String       @id @default(cuid())
  title         String
  description   String
  price         Float
  durationHours Int
  maxGroupSize  Int?
  images        String[]
  meetingPoint  String
  inclusions    String[]     @default([])
  exclusions    String[]     @default([])
  isActive      Boolean      @default(true)
  includes      String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  guideId       String
  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model GuideKYC {
  id              String       @id @default(cuid())
  guideProfileId  String
  type            String       // AADHAAR, PAN, DRIVING_LICENSE, GUIDE_CERTIFICATE
  documentUrl     String
  status          String       @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText   String?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  guideProfile    GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)

  @@map("guide_kyc_documents")
}

model GuidePayout {
  id              String       @id @default(cuid())
  guideProfileId  String
  amount          Float
  commission      Float
  netAmount       Float
  status          String       @default("PENDING") // PENDING, PAID, FAILED
  bankName        String?
  accountName     String?
  accountNumber   String?
  ifsc            String?
  transactionRef  String?
  createdAt       DateTime     @default(now())
  paidAt          DateTime?
  guideProfile    GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)

  @@map("guide_payouts")
}

model Message {
  id        String   @id @default(cuid())
  text      String
  senderId  String
  bookingId String
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model StaffMember {
  id        String   @id @default(cuid())
  role      String
  resortId  String
  userId    String   @unique
  createdAt DateTime @default(now())
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_members")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String
  resortId  String
  code      String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

enum Role {
  TRAVELLER
  RESORT_OWNER
  ADMIN
  GUIDE
  STAFF
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  CHECKED_IN
  CANCELLED
  COMPLETED
}

enum ResortStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_SUBMITTED
  UNDER_REVIEW
  RESUBMITTED
  VERIFIED
}

model PendingVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String
  passwordHash String
  role         Role     @default(TRAVELLER)
  otpHash      String
  otpType      String // "email" or "mobile"
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("pending_verifications")
}

model VerificationAudit {
  id              String   @id @default(cuid())
  adminId         String
  adminName       String?
  targetUserId    String
  targetName      String?
  targetType      String // "GUIDE" or "RESORT"
  action          String // "APPROVED", "REJECTED", "SUBMITTED"
  rejectionReason String?
  previousStatus  String?
  newStatus       String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@map("verification_audits")
}

model HomepageHero {
  id             String    @id @default(cuid())
  title          String
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  ctaText        String?
  ctaLink        String?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("homepage_heroes")
}

model ResortAmenity {
  id          String   @id @default(cuid())
  resortId    String
  name        String
  type        String // "PREDEFINED" | "CUSTOM"
  icon        String?
  description String?
  createdAt   DateTime @default(now())
  resort      Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("resort_amenities")
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  type           String // PERCENTAGE, FLAT, REFERRAL, FIRST_BOOKING, REWARD
  discountValue  Float
  minBookingAmt  Float?
  maxDiscountAmt Float?
  validFrom      DateTime
  validUntil     DateTime
  maxUsesTotal   Int?
  maxUsesPerUser Int      @default(1)
  currentUses    Int      @default(0)
  isActive       Boolean  @default(true)

  resortId      String?
  roomId        String?
  region        String?
  userRole      String?
  onlyFirstTime Boolean @default(false)

  redemptions CouponRedemption[]
  resort      Resort?            @relation("ResortCoupons", fields: [resortId], references: [id])

  @@map("coupons")
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  userId      String
  bookingId   String?  @unique
  discountAmt Float
  redeemedAt  DateTime @default(now())

  coupon  Coupon   @relation(fields: [couponId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@unique([couponId, userId, bookingId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referredUserId String    @unique
  referralCode   String
  status         String    @default("PENDING") // PENDING, COMPLETED
  rewardAmount   Float     @default(0)
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  referrer     User @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@map("referrals")
}

model RewardCredit {
  id        String    @id @default(cuid())
  userId    String
  amount    Float
  source    String // REFERRAL, CASHBACK, PROMOTION
  status    String    @default("AVAILABLE") // AVAILABLE, USED, EXPIRED
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("reward_credits")
}

model SeasonalCampaign {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  bannerUrl String?
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seasonal_campaigns")
}

model SponsoredPlacement {
  id        String   @id @default(cuid())
  resortId  String
  placement String
  priority  Int
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("sponsored_placements")
}

model CuratedExperience {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  price       Float
  duration    String
  location    String
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("curated_experiences")
}

model AdminSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Promotion {
  id                String   @id @default(cuid())
  name              String
  code              String?  @unique
  description       String?

  discountType      String
  discountValue     Float

  minBookingAmount  Float?
  maxDiscount       Float?

  firstBookingOnly  Boolean @default(false)
  maxUsesPerUser    Int?

  usageLimit        Int?
  usageCount        Int @default(0)

  active            Boolean @default(true)
  autoApply         Boolean @default(false)

  validFrom         DateTime?
  validUntil        DateTime?

  priority          Int @default(1)

  applicableRoles   String?
  targetType        String @default("PLATFORM") // PLATFORM, RESORT, CATEGORY, OWNER
  targetId          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bookings          Booking[]
}

model MediaHash {
  id        String   @id @default(cuid())
  hash      String   @unique
  url       String
  userId    String?
  createdAt DateTime @default(now())
  
  @@map("media_hashes")
}
