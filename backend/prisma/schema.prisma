generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String             @id @default(cuid())
  email                   String             @unique
  name                    String
  passwordHash            String
  role                    Role               @default(TRAVELLER)
  avatar                  String?
  phone                   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  idImage                 String?
  idNumber                String?
  idType                  String?
  isEmailVerified         Boolean            @default(false)
  mfaSecret               String?
  isMfaEnabled            Boolean            @default(false)
  theme                   String             @default("light")
  language                String             @default("en-US")
  isMobileVerified        Boolean            @default(false)
  verifiedEmail           Boolean            @default(false)
  verifiedPhone           Boolean            @default(false)
  verificationCompletedAt DateTime?
  kycStatus               String?            @default("NOT_SUBMITTED")
  kycRejectionReason      String?
  deletedAt               DateTime?
  fraudScore              Int                @default(0)
  myReferralCode          String?            @unique
  fraudFlags              String[]           @default([])
  location                String?
  bookings                Booking[]
  guideBookings           GuideBooking[]
  guideProfile            GuideProfile?
  messages                Message[]
  notifications           Notification[]
  otpVerifications        OtpVerification[]
  ownerProfile            ResortOwner?
  reviews                 Review[]
  staffProfile            StaffMember?
  wishlist                Wishlist[]
  couponRedemptions       CouponRedemption[]
  referralsSent           Referral[]         @relation("Referrer")
  referralsReceived       Referral[]         @relation("ReferredUser")
  rewardCredits           RewardCredit[]
  blogPosts               BlogPost[]         @relation("BlogAuthor")
  adminSessions           AdminSession[]
  auditLogs               AuditLog[]
  travellerKycDocuments   TravellerKYC[]
  guideReviews            GuideReview[]

  @@map("users")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  otpHash   String
  otpType   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phone])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model Resort {
  payouts ResortOwnerPayout[]

  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  tagline          String
  description      String
  type             String
  locationArea     String
  locationLat      Float
  locationLng      Float
  images           String[]
  coverImage       String?
  amenities        String[]
  rating           Float           @default(0)
  reviewCount      Int             @default(0)
  pricePerNight    Float
  isFeatured       Boolean         @default(false)
  isVerified       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ownerId          String
  categories       String[]        @default([])
  houseRules       String[]
  mealPackages     Json?
  verificationDocs Json?
  status           ResortStatus    @default(PENDING)
  deletedAt        DateTime?
  commissionType   CommissionType  @default(GLOBAL)
  commissionRate   Float           @default(7.0)
  boostScore       Int             @default(0)
  bookings         Booking[]
  discountCodes    DiscountCode[]
  invitations      Invitation[]
  owner            ResortOwner     @relation(fields: [ownerId], references: [id])
  reviews          Review[]
  roomTypes        Room[]
  staff            StaffMember[]
  wishlist         Wishlist[]
  resortAmenities  ResortAmenity[]
  coupons          Coupon[]        @relation("ResortCoupons")
  housekeepingTasks HousekeepingTask[]

  @@index([status])
  @@index([pricePerNight])
  @@index([rating])
  @@index([type])
  @@index([isFeatured])
  @@index([ownerId])
  @@map("resorts")
}

model Room {
  id               String              @id @default(cuid())
  name             String
  description      String
  pricePerNight    Float
  capacity         Int
  amenities        String[]
  images           String[]
  coverImage       String?
  availableCount   Int
  resortId         String
  maxNights        Int                 @default(30)
  minNights        Int                 @default(1)
  externalIcalUrls String[]            @default([])
  bookings         Booking[]
  blockings        RoomBlocking[]
  priceOverrides   RoomPriceOverride[]
  photos           RoomPhoto[]
  housekeepingTasks HousekeepingTask[]
  resort           Resort              @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@map("rooms")
}

model RoomPhoto {
  id        String   @id @default(cuid())
  roomId    String
  imageUrl  String
  isCover   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_photos")
}

model RoomPriceOverride {
  id        String   @id @default(cuid())
  date      DateTime
  price     Float
  minNights Int?
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_price_overrides")
}

model SystemSettings {
  id                      String   @id @default(cuid())
  guideServiceEnabled     Boolean  @default(true)
  defaultCommissionRate   Float    @default(7.0)
  requireOtpForSignup     Boolean  @default(true)
  maintenanceMode         Boolean  @default(false)
  detailedAuditLogging    Boolean  @default(true)
  notifyNewUsers          Boolean  @default(true)
  notifyHighValueBookings Boolean  @default(true)
  notifySystemAlerts      Boolean  @default(true)
  updatedBy               String?
  updatedAt               DateTime @updatedAt
}

model GuidePromotionSettings {
  id                    String   @id @default(cuid())
  enableRecommendations Boolean  @default(true)
  enableSuccessUpsell   Boolean  @default(true)
  enableDashboardBanner Boolean  @default(true)
  enableBundleOffers    Boolean  @default(true)
  bundleDiscountAmount  Float    @default(200.0)
  bannerText            String   @default("🏛️ Explore Hampi With a Local Expert")
  ctaText               String   @default("Explore Guides")
  updatedBy             String?
  updatedAt             DateTime @updatedAt

  @@map("guide_promotion_settings")
}

model OtaIntegration {
  id           String    @id @default(cuid())
  provider     String    @unique // APIFY, BRIGHT_DATA, SITEMINDER
  apiKey       String?
  endpoint     String?
  isActive     Boolean   @default(false)
  lastSyncAt   DateTime?
  syncStatus   String?   // SUCCESS, FAILED, SYNCING
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("ota_integrations")
}

model GuidePromotionAnalytics {
  id                String   @id @default(cuid())
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  profileViews      Int      @default(0)
  guideBookings     Int      @default(0)
  bundleConversions Int      @default(0)
  revenueGenerated  Float    @default(0.0)
  date              DateTime @default(now())

  @@map("guide_promotion_analytics")
}

model VerificationSettings {
  id                      String   @id @default(cuid())
  travellerRequirements   String[] @default(["MOBILE_OTP", "EMAIL_VERIFICATION"])
  resortOwnerRequirements String[] @default(["AADHAAR", "PAN"])
  guideRequirements       String[] @default(["AADHAAR"])
  updatedBy               String?
  updatedAt               DateTime @updatedAt

  @@map("verification_settings")
}

model RoomBlocking {
  id     String   @id @default(cuid())
  date   DateTime
  reason String?
  roomId String
  room   Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_blockings")
}

model DiscountCode {
  id               String   @id @default(cuid())
  code             String   @unique
  percentage       Float?
  flatAmount       Float?
  minBookingAmt    Float?
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  usedCount        Int      @default(0)
  isEarlyBird      Boolean  @default(false)
  minDaysInAdvance Int?
  isLastMinute     Boolean  @default(false)
  maxDaysInAdvance Int?
  resortId         String
  resort           Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("discount_codes")
}

model Booking {
  payout ResortOwnerPayout?
  refundRequest RefundRequest?

  id              String        @id @default(cuid())
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  specialRequests String?
  referenceNumber String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  resortId        String
  roomId          String?
  commissionRate  Float         @default(7.0)
  paymentStatus   String        @default("PENDING")
  payoutStatus    String        @default("PENDING")

  promotionId    String?
  promotionName  String?
  discountAmount Float?
  promotion      Promotion? @relation(fields: [promotionId], references: [id])

  resort           Resort            @relation(fields: [resortId], references: [id])
  room             Room?             @relation(fields: [roomId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  messages         Message[]
  couponRedemption CouponRedemption?

  @@index([resortId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([checkIn])
  @@index([checkOut])
  @@index([resortId, status])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Wishlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resortId])
  @@map("wishlist")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int      @default(5)
  comment    String?
  images     String[]
  ownerReply String?
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  userId     String
  resortId   String
  bookingId  String?  @unique
  resort     Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@index([userId])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  content         String    @db.Text
  excerpt         String?
  featuredImage   String?
  authorId        String
  categoryId      String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  metaTitle       String?
  metaDescription String?
  isFeatured      Boolean   @default(false)
  tags            String[]  @default([])

  author User @relation("BlogAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([publishedAt])
  @@map("blog_posts")
}

model ResortOwner {
  payouts ResortOwnerPayout[]
  settlements SettlementLedger[]

  id           String        @id @default(cuid())
  businessName String?
  gstNumber    String?
  isVerified   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resorts      Resort[]
  kycDocuments KycDocument[]
  bankAccount  BankAccount?

  @@map("resort_owners")
}

model KycDocument {
  id             String      @id @default(cuid())
  ownerId        String
  type           String // AADHAAR, PAN
  documentUrl    String
  status         String      @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText  String?
  rejectedReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  owner          ResortOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("kyc_documents")
}

model BankAccount {
  id            String      @id @default(cuid())
  ownerId       String      @unique
  accountHolder String
  bankName      String
  accountNumber String
  ifsc          String
  status        String      @default("PENDING") // PENDING, VERIFIED, REJECTED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  owner         ResortOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model TravellerKYC {
  id             String   @id @default(cuid())
  userId         String
  type           String // GOVERNMENT_ID, AADHAAR, PASSPORT
  documentUrl    String
  status         String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText  String?
  rejectedReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("traveller_kyc_documents")
}

model GuideProfile {
  id                String         @id @default(cuid())
  bio               String
  specialties       String[]
  languages         String[]
  pricePerDay       Float
  pricePerHour      Float
  yearsExperience   Int
  contactNumber     String?
  emergencyContact  String?
  city              String?
  state             String?
  profileCompletion Int            @default(0)
  isVerified        Boolean        @default(false)
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  images            String[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  userId            String         @unique
  idImage           String?
  idNumber          String?
  idType            String?
  status            ResortStatus   @default(PENDING)
  rejectionReason   String?
  isActive          Boolean        @default(true)
  bankName          String?
  accountName       String?
  accountNumber     String?
  ifsc              String?
  deletedAt         DateTime?
  fraudScore        Int            @default(0)
  fraudFlags        String[]       @default([])
  experiences       Experience[]
  bookings          GuideBooking[]
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycDocuments      GuideKYC[]
  payouts           GuidePayout[]
  blockedDates      DateTime[]     @default([])
  reviews           GuideReview[]

  @@map("guide_profiles")
}

model GuideBooking {
  id              String        @id @default(cuid())
  date            DateTime
  durationHours   Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  meetingPoint    String
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  guideId         String
  guide           GuideProfile  @relation(fields: [guideId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  messages        Message[]
  review          GuideReview?
  payout          GuidePayout?

  @@index([guideId])
  @@index([userId])
  @@index([date])
  @@map("guide_bookings")
}

model Experience {
  id            String       @id @default(cuid())
  title         String
  description   String
  price         Float
  durationHours Int
  maxGroupSize  Int?
  images        String[]
  meetingPoint  String
  inclusions    String[]     @default([])
  exclusions    String[]     @default([])
  isActive      Boolean      @default(true)
  includes      String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  guideId       String
  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model GuideKYC {
  id              String       @id @default(cuid())
  guideProfileId  String
  type            String // AADHAAR, PAN, DRIVING_LICENSE, GUIDE_CERTIFICATE
  documentUrl     String
  status          String       @default("PENDING") // PENDING, VERIFIED, REJECTED
  extractedText   String?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  guideProfile    GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)

  @@index([guideProfileId])
  @@map("guide_kyc_documents")
}

model GuidePayout {
  id             String       @id @default(cuid())
  guideProfileId String
  amount         Float
  commission     Float
  netAmount      Float
  status         String       @default("PENDING") // PENDING, PAID, FAILED
  bankName       String?
  accountName    String?
  accountNumber  String?
  ifsc           String?
  transactionRef String?
  createdAt      DateTime     @default(now())
  paidAt         DateTime?
  bookingId      String?      @unique
  lockedUntil    DateTime?
  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  booking        GuideBooking? @relation(fields: [bookingId], references: [id])

  @@map("guide_payouts")
}

model Message {
  id             String        @id @default(cuid())
  text           String
  senderId       String
  bookingId      String?
  guideBookingId String?
  createdAt      DateTime      @default(now())
  booking        Booking?      @relation(fields: [bookingId], references: [id])
  guideBooking   GuideBooking? @relation(fields: [guideBookingId], references: [id])
  sender         User          @relation(fields: [senderId], references: [id])

  @@index([bookingId])
  @@index([guideBookingId])
  @@index([senderId])
  @@map("messages")
}



model StaffMember {
  id        String   @id @default(cuid())
  role      String
  resortId  String
  userId    String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  resort        Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  housekeepingTasks HousekeepingTask[]

  @@index([resortId])
  @@map("staff_members")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String
  resortId  String
  code      String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@map("invitations")
}

enum Role {
  TRAVELLER
  RESORT_OWNER
  ADMIN
  GUIDE
  STAFF
}

enum CommissionType {
  GLOBAL
  CUSTOM
}

enum BookingStatus {
  PENDING
  PAID
  CONFIRMED
  CHECKED_IN
  CANCELLED
  COMPLETED
}

enum ResortStatus {
  DRAFT
  KYC_PENDING
  PENDING
  UNDER_REVIEW
  APPROVED
  ACTIVE
  REJECTED
  NOT_SUBMITTED
  RESUBMITTED
  VERIFIED
}

model PendingVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String
  passwordHash String
  role         Role     @default(TRAVELLER)
  otpHash      String
  otpType      String // "email" or "mobile"
  expiresAt    DateTime
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("pending_verifications")
}

model VerificationAudit {
  id              String   @id @default(cuid())
  adminId         String
  adminName       String?
  targetUserId    String
  targetName      String?
  targetType      String // "GUIDE" or "RESORT"
  action          String // "APPROVED", "REJECTED", "SUBMITTED"
  rejectionReason String?
  previousStatus  String?
  newStatus       String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([targetUserId])
  @@index([adminId])
  @@index([createdAt])
  @@map("verification_audits")
}

model HomepageHero {
  id             String    @id @default(cuid())
  title          String
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  ctaText        String?
  ctaLink        String?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("homepage_heroes")
}

model ResortAmenity {
  id          String   @id @default(cuid())
  resortId    String
  name        String
  type        String // "PREDEFINED" | "CUSTOM"
  icon        String?
  description String?
  createdAt   DateTime @default(now())
  resort      Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@map("resort_amenities")
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  type           String // PERCENTAGE, FLAT, REFERRAL, FIRST_BOOKING, REWARD
  discountValue  Float
  minBookingAmt  Float?
  maxDiscountAmt Float?
  validFrom      DateTime
  validUntil     DateTime
  maxUsesTotal   Int?
  maxUsesPerUser Int      @default(1)
  currentUses    Int      @default(0)
  isActive       Boolean  @default(true)

  resortId      String?
  roomId        String?
  region        String?
  userRole      String?
  onlyFirstTime Boolean @default(false)

  redemptions CouponRedemption[]
  resort      Resort?            @relation("ResortCoupons", fields: [resortId], references: [id])

  @@map("coupons")
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  userId      String
  bookingId   String?  @unique
  discountAmt Float
  redeemedAt  DateTime @default(now())

  coupon  Coupon   @relation(fields: [couponId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@unique([couponId, userId, bookingId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referredUserId String    @unique
  referralCode   String
  status         String    @default("PENDING") // PENDING, COMPLETED
  rewardAmount   Float     @default(0)
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  referrer     User @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@map("referrals")
}

model RewardCredit {
  id        String    @id @default(cuid())
  userId    String
  amount    Float
  source    String // REFERRAL, CASHBACK, PROMOTION
  status    String    @default("AVAILABLE") // AVAILABLE, USED, EXPIRED
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reward_credits")
}

model SeasonalCampaign {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  bannerUrl String?
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seasonal_campaigns")
}

model SponsoredPlacement {
  id        String   @id @default(cuid())
  resortId  String
  placement String
  priority  Int
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("sponsored_placements")
}

model CuratedExperience {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  price       Float
  duration    String
  location    String
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("curated_experiences")
}

model AdminSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Promotion {
  id          String  @id @default(cuid())
  name        String
  code        String? @unique
  description String?

  discountType  String
  discountValue Float

  minBookingAmount Float?
  maxDiscount      Float?

  firstBookingOnly Boolean @default(false)
  maxUsesPerUser   Int?

  usageLimit Int?
  usageCount Int  @default(0)

  active    Boolean @default(true)
  autoApply Boolean @default(false)

  validFrom  DateTime?
  validUntil DateTime?

  priority Int @default(1)

  applicableRoles String?
  targetType      String  @default("PLATFORM") // PLATFORM, RESORT, CATEGORY, OWNER
  targetId        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model MediaHash {
  id        String   @id @default(cuid())
  hash      String   @unique
  url       String
  userId    String?
  createdAt DateTime @default(now())

  @@map("media_hashes")
}

model ExternalPropertyPresence {
  id               String   @id @default(cuid())
  resortName       String
  bookingComUrl    String?
  airbnbUrl        String?
  goibiboUrl       String?
  makemytripUrl    String?
  agodaUrl         String?
  expediaUrl       String?
  detectedChannels String?
  reviewVolume     Int      @default(0)
  rating           Float?
  opportunityScore Int      @default(0)
  lastChecked      DateTime @default(now())

  @@map("external_property_presence")
}

model ResortOwnerPayout {
  id                 String   @id @default(cuid())
  bookingId          String   @unique
  resortId           String
  ownerId            String
  grossAmount        Float
  commissionRate     Float
  platformCommission Float
  netAmount          Float
  status             String   @default("PENDING")
  settlementId       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  settlement SettlementLedger? @relation(fields: [settlementId], references: [id])
  booking    Booking           @relation(fields: [bookingId], references: [id])
  resort     Resort            @relation(fields: [resortId], references: [id])
  owner      ResortOwner       @relation(fields: [ownerId], references: [id])

  @@index([resortId])
  @@index([ownerId])
  @@index([status])
  @@map("resort_owner_payouts")
}

model SettlementLedger {
  id              String    @id @default(cuid())
  ownerId         String
  totalGross      Float
  totalCommission Float
  totalNet        Float
  status          String    @default("PENDING")
  transactionRef  String?
  settlementDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payouts ResortOwnerPayout[]
  owner   ResortOwner         @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@map("settlement_ledgers")
}

model OtaMarketData {
  id               String   @id @default(uuid())
  resortName       String
  bookingComUrl    String?
  airbnbUrl        String?
  goibiboUrl       String?
  makemytripUrl    String?
  agodaUrl         String?
  expediaUrl       String?
  detectedChannels String?
  reviewVolume     Int      @default(0)
  rating           Float?
  opportunityScore Int      @default(0)

  // Scraped Prices
  bookingComPrice  Float?
  makemytripPrice  Float?
  airbnbPrice      Float?
  agodaPrice       Float?
  hampistaysPrice  Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("ota_market_data")
}

model HousekeepingTask {
  id          String       @id @default(cuid())
  resortId    String
  roomNumber  String       // The physical room number, e.g., "101"
  roomTypeId  String       // Refers to the Room (type) model
  status      String       @default("DIRTY") // DIRTY, CLEANING, READY
  staffId     String?      // Refers to StaffMember
  notes       String?
  lastCleaned DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  resort      Resort       @relation(fields: [resortId], references: [id], onDelete: Cascade)
  roomType    Room         @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  staff       StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([resortId])
  @@index([roomTypeId])
  @@index([staffId])
  @@index([status])
  @@map("housekeeping_tasks")
}

model RefundRequest {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  amount      Float
  reason      String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, PROCESSING
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking     Booking  @relation(fields: [bookingId], references: [id])

  @@map("refund_requests")
}

model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  category    String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  userName    String
  userEmail   String
  userPhone   String?
  resortName  String?
  bookingId   String?
  userId      String?
  
  messages    SupportMessage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  sender      String   // USER, ADMIN
  senderName  String
  content     String
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

model Campaign {
  id              String   @id @default(cuid())
  title           String
  subject         String
  body            String
  audience        String   // ALL, TRAVELLERS, RESORT_OWNERS, GUIDES
  status          String   @default("DRAFT")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int      @default(0)
  openRate        Float?
  clickRate       Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("campaigns")
}

model GuideReview {
  id             String       @id @default(cuid())
  guideProfileId String
  userId         String
  bookingId      String       @unique
  rating         Int
  reviewText     String?
  guideReply     String?
  status         String       @default("APPROVED") // APPROVED, FLAGGED
  flagReason     String?
  createdAt      DateTime     @default(now())

  guideProfile   GuideProfile @relation(fields: [guideProfileId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking        GuideBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([userId, bookingId]) // 1 review per user per booking
  @@map("guide_reviews")
}
